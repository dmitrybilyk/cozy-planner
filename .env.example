# PostgreSQL
DB_USER=user
DB_PASSWORD=your_strong_password_here
DB_NAME=planner_db

# Google OAuth2 — create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# App public URL (used for OAuth redirect & Telegram webhook)
APP_BASE_URL=https://your-oracle-cloud-public-ip

# Telegram (optional — set to false if not using)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
MENTOR_TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_URL=
MENTOR_TELEGRAM_WEBHOOK_URL=

# Scheduler
SCHEDULER_WEEKEND_REMINDER_CRON=0 0 16 * * FRI
SCHEDULER_SESSION_REMINDER_CRON=0 */5 * * * *

# Flyway (set to true only if you want to reset DB on each start)
FLYWAY_CLEAN_ON_START=false

# JVM
JAVA_OPTS=-Xmx512m -Xms256m
