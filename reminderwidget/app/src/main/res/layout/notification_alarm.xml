<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/notif_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingBottom="2dp" />

    <TextView
        android:id="@+id/notif_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#888888"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingBottom="4dp"
        android:visibility="gone" />

    <!-- Pinned-mode row: repeat + postpone + unpin/calendar + done -->
    <LinearLayout
        android:id="@+id/pinned_row"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <Button
            android:id="@+id/btn_snooze_pin"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:text="🔁"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:padding="0dp" />

        <Button
            android:id="@+id/btn_postpone_day"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:text="⏩ Завтра"
            android:textSize="10sp"
            android:textAllCaps="false"
            android:padding="0dp" />

        <ImageButton
            android:id="@+id/btn_add_calendar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:padding="5dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_export_gc"
            android:background="@android:color/transparent"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_done_pinned"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="✅"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:background="@android:color/transparent"
            android:padding="0dp" />

    </LinearLayout>

    <!-- Normal-mode row: snooze A + snooze B + done + repeat + pin -->
    <LinearLayout
        android:id="@+id/row_buttons"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_snooze_a"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:text="⏰"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:padding="2dp" />

        <Button
            android:id="@+id/btn_snooze_b"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:text="⏰"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:padding="2dp" />

        <Button
            android:id="@+id/btn_done"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:text="✅"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:padding="2dp" />

        <Button
            android:id="@+id/btn_repeat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:text="🔁"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:padding="2dp" />

        <Button
            android:id="@+id/btn_pin"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="📌"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:padding="2dp" />

    </LinearLayout>

</LinearLayout>
