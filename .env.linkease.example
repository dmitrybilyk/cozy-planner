# Template for /etc/linkease/secrets.env on the Oracle Cloud VM (own file, separate from
# /etc/planner/secrets.env — does not touch planner's secrets or containers).

# PostgreSQL (own DB, own volume — isolated from planner-db)
LINKEASE_DB_USER=user
LINKEASE_DB_PASSWORD=your_strong_password_here
LINKEASE_DB_NAME=linkease_db

# Google OAuth2 — reuse the SAME client ID/secret values planner uses
# (same Google Cloud OAuth client, independent code/session store).
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=your_google_client_secret

# Single-tenant gate — only this Google account may log in.
LINKEASE_OWNER_EMAIL=you@example.com

# App public URL (used for OAuth redirect & Telegram webhook)
LINKEASE_APP_BASE_URL=https://92.5.42.35:8443

# TLS keystore password (same keystore.p12 file already mounted for planner)
KEYSTORE_PASSWORD=035645

# Telegram — NEW, independent bot (own token via @BotFather, not planner's bots)
LINKEASE_TELEGRAM_ENABLED=true
LINKEASE_TELEGRAM_BOT_TOKEN=
LINKEASE_TELEGRAM_BOT_USERNAME=
LINKEASE_TELEGRAM_WEBHOOK_URL=https://92.5.42.35:8443/api/telegram/webhook
LINKEASE_TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_REMINDER_MINUTES_BEFORE=60

# JVM
JAVA_OPTS=-XX:+UseSerialGC -Xms128m -Xmx192m
