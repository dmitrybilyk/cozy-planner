# Lightweight runtime image — wraps a pre-built Spring Boot fat-JAR.
# Build the JAR locally first (Wasm compilation runs on your machine, not the server):
#   cd linkease && ./gradlew :server:bootJar -Plinkease.wasmDist=production
# Then deploy via deploy_linkease.sh which ships the JAR here.
FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY app.jar app.jar
ENV JAVA_OPTS="-XX:+UseSerialGC -Xms128m -Xmx192m"
ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -jar app.jar"]
